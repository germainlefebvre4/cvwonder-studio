# ── Server ─────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080
# FRONTEND_BASE_URL=http://localhost:5173  # Set this in dev when frontend runs on a different port than the backend.
                                           # Defaults to APP_BASE_URL when unset (correct for single-origin production).
PORT=8080

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://cvwonder:cvwonder@localhost:5432/cvwonder?sslmode=disable

# ── CVWonder binary ─────────────────────────────────────────────────────────
CVWONDER_BINARY_PATH=../bin/cvwonder

# ── Sessions ────────────────────────────────────────────────────────────────
SESSIONS_BASE_DIR=../sessions
SESSION_DURATION_DAYS=30

# ── Themes ──────────────────────────────────────────────────────────────────
THEMES_BUILTIN_DIR=../infra/themes
THEMES_RUNTIME_DIR=../themes

# ── Admin credentials (required) ─────────────────────────────────────────────
# Generate a bcrypt hash for the admin password (cost factor 12 recommended):
#   htpasswd -bnBC 12 "" yourpassword | tr -d ':\n' | sed 's/$2y/$2a/'
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt(12)).decode())"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$replacethiswithyourrealhashxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Generate a random secret (32+ characters recommended):
#   openssl rand -hex 32
ADMIN_TOKEN_SECRET=change-me-to-a-random-secret-of-at-least-32-chars

# ── Google OAuth (optional — omit or leave empty to disable user auth) ────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
USER_TOKEN_SECRET=change-me-to-a-random-secret-of-at-least-32-chars

# ── Development overrides ─────────────────────────────────────────────────────
# Set to "true" to bypass the session creation rate limit (3 sessions/hour/IP).
# DEV ONLY — never enable this in production.
DISABLE_SESSION_CREATION_RATE_LIMIT=false
