{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "CVWonder Studio Helm Chart Values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "commonMetaLabels": { "type": "object" },
    "imagePullSecrets": {
      "type": "array",
      "items": { "type": "object" }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "digest": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["IfNotPresent", "Always", "Never"]
        }
      }
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "revisionHistoryLimit": {
      "type": "integer",
      "minimum": 0
    },
    "strategy": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Recreate", "RollingUpdate"]
        }
      }
    },
    "priorityClassName": { "type": "string" },
    "runtimeClassName": { "type": "string" },
    "config": {
      "type": "object",
      "properties": {
        "port": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "sessionsBaseDir": { "type": "string" },
        "themesBuiltinDir": { "type": "string" },
        "themesRuntimeDir": { "type": "string" },
        "cvwonderBinaryPath": { "type": "string" },
        "sessionDurationDays": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "appBaseUrl": { "type": "string" },
        "frontendBaseUrl": { "type": "string" }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "databaseUrl": { "type": "string" },
        "userTokenSecret": { "type": "string" },
        "adminUsername": { "type": "string" },
        "adminPasswordHash": { "type": "string" },
        "adminTokenSecret": { "type": "string" },
        "googleClientId": { "type": "string" },
        "googleClientSecret": { "type": "string" }
      }
    },
    "existingSecret": { "type": "string" },
    "storage": {
      "type": "object",
      "properties": {
        "sessions": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "existingClaim": { "type": "string" },
            "accessModes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "size": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti|Pi|Ei|K|M|G|T|P|E)?$"
            },
            "storageClass": { "type": "string" },
            "labels": { "type": "object" },
            "annotations": { "type": "object" }
          }
        },
        "themes": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "existingClaim": { "type": "string" },
            "accessModes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "size": {
              "type": "string",
              "pattern": "^[0-9]+(\\.[0-9]+)?(Ki|Mi|Gi|Ti|Pi|Ei|K|M|G|T|P|E)?$"
            },
            "storageClass": { "type": "string" },
            "labels": { "type": "object" },
            "annotations": { "type": "object" }
          }
        }
      }
    },
    "resources": { "type": "object" },
    "securityContext": { "type": "object" },
    "containerSecurityContext": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": {
      "type": "array",
      "items": { "type": "object" }
    },
    "affinity": { "type": "object" },
    "podAntiAffinity": {
      "type": "string",
      "enum": ["", "soft", "hard"]
    },
    "podAntiAffinityTopologyKey": { "type": "string" },
    "topologySpreadConstraints": {
      "type": "array",
      "items": { "type": "object" }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "deploymentAnnotations": { "type": "object" },
    "hostAliases": {
      "type": "array",
      "items": { "type": "object" }
    },
    "dnsPolicy": { "type": "string" },
    "dnsConfig": { "type": "object" },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0
    },
    "extraInitContainers": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraContainers": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraVolumes": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraVolumeMounts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "extraEnv": {
      "type": "array",
      "items": { "type": "object" }
    },
    "service": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "labels": { "type": "object" },
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"]
        },
        "port": { "type": "integer" },
        "clusterIP": { "type": "string" },
        "externalIPs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "loadBalancerIP": { "type": "string" },
        "loadBalancerSourceRanges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sessionAffinity": { "type": "string" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressClassName": { "type": "string" },
        "annotations": { "type": "object" },
        "extraLabels": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "path": { "type": "string" },
        "pathType": {
          "type": "string",
          "enum": ["Prefix", "Exact", "ImplementationSpecific"]
        },
        "tls": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        }
      }
    },
    "migrations": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["IfNotPresent", "Always", "Never"]
            }
          }
        },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "resources": { "type": "object" },
        "annotations": { "type": "object" },
        "podAnnotations": { "type": "object" }
      }
    },
    "gotenberg": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "digest": { "type": "string" },
            "pullPolicy": {
              "type": "string",
              "enum": ["IfNotPresent", "Always", "Never"]
            }
          }
        },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "resources": { "type": "object" },
        "securityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
            },
            "port": { "type": "integer" },
            "annotations": { "type": "object" }
          }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": {
          "type": "array",
          "items": { "type": "object" }
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "forceNamespace": { "type": "string" },
    "extraManifests": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
